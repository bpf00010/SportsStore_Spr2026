@page
@model SportsStore_Spr2026.Pages.Customers.Home.ShoppingCartModel



<h2>Your Shopping Cart</h2>

<form method="post">
    <table class="table">
        <thead>
            <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.CartItems.Count; i++)
            {
                
                <tr>
                    <td>@Model.CartItems[i].ProductName</td>
                    <td>

                        <input asp-for="@Model.CartItems[i].CartID" type="hidden" />
                        <input asp-for="@Model.CartItems[i].ProductName" type="hidden" />
                        <input asp-for="@Model.CartItems[i].ProductID" type="hidden" />


                        <input asp-for="@Model.CartItems[i].Quantity" min="0" class="form-control" />
                    </td>
                    <td>@Model.CartItems[i].Price.ToString("C")</td>
                    <td>@Model.CartItems[i].Quantity</td>
                    <td>@Model.CartItems[i].Subtotal.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="text-end mt-3">
        Total : @Model.CartTotal.ToString("C")

    </div>


    <button type="submit" class="btn btn-primary mt-3">Update Cart</button>






</form>

